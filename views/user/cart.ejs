<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | BookStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">

    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" type="text/css" href="/icomoon/icomoon.css">
    <link rel="stylesheet" type="text/css" href="/css/index.css">

    <style>
        .cart-table th {
            background-color: var(--light-color);
            font-family: var(--heading-font);
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .cart-product-img {
            width: 60px;
            height: 80px;
            object-fit: cover;
            border-radius: 4px;
        }
        .qty-btn {
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #ccc;
            background: #fff;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
            border-radius: 4px;
        }
        .qty-btn:hover {
            background: var(--light-color);
        }
        .qty-display {
            width: 45px;
            text-align: center;
            font-weight: 600;
            border: none;
            background: transparent;
        }
        .unavailable-row {
            background-color: #ffebee;
            opacity: 0.8;
        }
        .warning-text {
            color: #c62828;
            font-size: 0.85em;
            font-weight: 600;
        }
        .checkout-card {
            border: 1px solid #eee;
            border-radius: 8px;
            background: #fafafa;
        }
    </style>

    <script defer src="/js/jquery-1.11.0.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-HwwvtgBNo3bZJJLYd8oVXjrBZt8cqVSpeBNS5n7C8IVInixGAoxmnlMuBnhbgrkm"
        crossorigin="anonymous"></script>
    <script defer src="/js/plugins.js"></script>
    <script defer src="/js/script.js"></script>
</head>
<body>

    <div id="header-wrap" class="sticky-top bg-white shadow-sm">
        <div class="top-content">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-6">
                        <div class="social-links">
                            <ul>
                                <li><a href="#"><i class="icon icon-facebook"></i></a></li>
                                <li><a href="#"><i class="icon icon-twitter"></i></a></li>
                                <li><a href="#"><i class="icon icon-youtube-play"></i></a></li>
                                <li><a href="#"><i class="icon icon-behance-square"></i></a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="right-element d-flex align-items-center justify-content-end">
                            <form action="/logout" method="POST" class="d-inline m-0 p-0 me-3">
                                <button type="submit" class="user-login for-buy" style="background: transparent; border: none; padding: 0; margin: 0; font: inherit; color: inherit; cursor: pointer; display: inline-flex; align-items: center; text-transform: inherit; letter-spacing: inherit; position: static;">
                                    <i class="icon icon-login"></i><span>Logout</span>
                                </button>
                            </form>  
                            <a href="/profile/user" class="user-account for-buy me-3"><i class="icon icon-user"></i><span>Account</span></a>
                            <a href="/cart" class="cart for-buy"><i class="icon icon-clipboard"></i><span>Cart:(<%= cartCount %>)</span></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <header id="header">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-md-2">
                        <div class="main-logo">
                            <a href="/home"><img src="/images/main-logo.png" alt="logo"></a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <nav id="navbar">
                            <div class="main-menu stellarnav">
                                <ul class="menu-list">
                                    <li class="menu-item"><a href="/home">Home</a></li>
                                    <li class="menu-item"><a href="/home#featured-books">Featured</a></li>
                                    <li class="menu-item"><a href="/home#popular-books">Popular</a></li>
                                    <li class="menu-item"><a href="/home#special-offer">Offer</a></li>
                                    <li class="menu-item"><a href="/home#latest-blog">Articles</a></li>
                                </ul>
                            </div>
                        </nav>
                    </div>
                    <div class="col-md-4 text-end">
                        <a href="/wishlist" class="btn btn-outline-secondary btn-sm" style="font-weight: 600;"><i class="icon icon-heart-o me-1"></i> Wishlist</a>
                    </div>
                </div>
            </div>
        </header>
    </div>

    <main class="container my-5">
        <h2 class="mb-4" style="font-family: var(--heading-font);">Shopping Cart</h2>

        <% if (success && success.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <% if (hasUnavailableItems || hasStockIssues) { %>
            <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
                <span style="font-size: 1.3em;">⚠️</span>
                <div>
                    Some items in your cart require attention. Please review availability or reduce quantities before checking out.
                </div>
            </div>
        <% } %>

        <% if (items.length === 0) { %>
            <div class="text-center py-5 border rounded bg-light">
                <p class="text-muted mb-4" style="font-size: 1.2em;">Your shopping cart is currently empty.</p>
                <a href="/home" class="btn btn-dark px-4 py-2" style="font-weight: 600;">Browse Books</a>
            </div>
        <% } else { %>
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle cart-table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Price</th>
                                    <th class="text-center" style="width: 150px;">Quantity</th>
                                    <th class="text-center">Total</th>
                                    <th class="text-center">Remove</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% items.forEach((item, index) => { %>
                                    <tr id="row-<%= item.product ? item.product._id : 'deleted-' + index %>" class="<%= item.isUnavailable ? 'unavailable-row' : '' %>">
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <% if (item.product && item.product.images && item.product.images.length > 0) { %>
                                                    <img src="/uploads/<%= item.product.images[0] %>" class="cart-product-img" alt="Product Image">
                                                <% } else { %>
                                                    <img src="/images/product-item1.jpg" class="cart-product-img" alt="Default Product Image">
                                                <% } %>
                                                <div>
                                                    <% if (item.product) { %>
                                                        <h5 class="mb-1" style="font-size: 1em;"><%= item.product.title %></h5>
                                                        <span class="text-muted d-block" style="font-size: 0.85em;">By <%= item.product.author %></span>
                                                        <% if (item.isUnavailable) { %>
                                                            <span class="warning-text d-block">⚠️ Product is currently unavailable</span>
                                                        <% } else if (item.stockError) { %>
                                                            <span class="warning-text d-block">⚠️ <%= item.stockError %></span>
                                                        <% } %>
                                                    <% } else { %>
                                                        <span class="warning-text">⚠️ Unavailable / Deleted Product</span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            ₹<%= item.product ? item.product.price : 0 %>
                                        </td>
                                        <td class="text-center">
                                            <% if (item.product && !item.isUnavailable) { %>
                                                <div class="d-flex align-items-center justify-content-center">
                                                    <button type="button" class="qty-btn" onclick="updateQty('<%= item.product._id %>', 'decrement')">-</button>
                                                    <input type="text" class="qty-display" id="qty-<%= item.product._id %>" value="<%= item.quantity %>" readonly>
                                                    <button type="button" class="qty-btn" onclick="updateQty('<%= item.product._id %>', 'increment')">+</button>
                                                </div>
                                            <% } else { %>
                                                <span class="text-muted"><%= item.quantity %></span>
                                            <% } %>
                                        </td>
                                        <td class="text-center font-monospace" id="total-<%= item.product ? item.product._id : 'deleted-' + index %>">
                                            ₹<%= item.itemTotal %>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-danger btn-sm border-0" onclick="removeItem('<%= item.product ? item.product._id : '' %>')">
                                                🗑️
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="checkout-card p-4">
                        <h4 class="mb-4" style="font-family: var(--heading-font);">Order Summary</h4>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Subtotal:</span>
                            <strong id="summary-subtotal">₹<%= cartSubtotal %></strong>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Shipping:</span>
                            <span class="text-success">FREE</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <span>Grand Total:</span>
                            <strong class="fs-4" id="summary-total">₹<%= cartSubtotal %></strong>
                        </div>

                        <% if (hasUnavailableItems || hasStockIssues) { %>
                            <button class="btn btn-dark w-100 py-3 disabled" style="font-weight:600; text-transform: uppercase;" disabled>
                                Checkout Blocked
                            </button>
                            <p class="text-center text-danger mt-2" style="font-size:0.8em; font-weight:600;">Fix cart alerts to unlock checkout</p>
                        <% } else { %>
                            <a href="/checkout" class="btn btn-dark w-100 py-3" style="font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">
                                Proceed to Checkout
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        <% } %>
    </main>

    <footer id="footer" class="bg-dark text-white py-5 mt-5">
        <div class="container text-center text-muted">
            <p>© 2026 Premium Booksaw Shop. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // AJAX quantity increment/decrement helper
        function updateQty(productId, action) {
            fetch('/cart/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, action })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // Update display
                    document.getElementById('qty-' + productId).value = data.quantity;
                    document.getElementById('total-' + productId).textContent = '₹' + data.itemTotal;
                    document.getElementById('summary-subtotal').textContent = '₹' + data.cartSubtotal;
                    document.getElementById('summary-total').textContent = '₹' + data.cartSubtotal;
                    
                    // Update navbar count
                    document.querySelectorAll('.cart span').forEach(el => {
                        el.textContent = 'Cart:(' + data.cartCount + ')';
                    });
                } else {
                    alert(data.error || 'Failed to update quantity.');
                }
            })
            .catch(err => console.error(err));
        }

        // AJAX remove item helper
        function removeItem(productId) {
            if (!productId) {
                // If this happens, it means the product was deleted from the backend but is still in the user's cart session.
                // Usually your backend route needs to support removing by a cart Item ID instead of product ID for this scenario.
                alert('Cannot remove an already deleted product using this method. Please clear your cart.');
                return;
            }
            if (!confirm('Are you sure you want to remove this item from your cart?')) return;

            fetch('/cart/remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // Remove row
                    const row = document.getElementById('row-' + productId);
                    if (row) row.remove();
                    
                    // Update totals
                    document.getElementById('summary-subtotal').textContent = '₹' + data.cartSubtotal;
                    document.getElementById('summary-total').textContent = '₹' + data.cartSubtotal;

                    // Update navbar count
                    document.querySelectorAll('.cart span').forEach(el => {
                        el.textContent = 'Cart:(' + data.cartCount + ')';
                    });

                    // Reload page if empty to show the empty message
                    if (data.cartCount === 0) {
                        window.location.reload();
                    }
                } else {
                    alert(data.error || 'Failed to remove item.');
                }
            })
            .catch(err => console.error(err));
        }
    </script>
</body>
</html>