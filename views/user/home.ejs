<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Home</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet"
		integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">

	<link rel="stylesheet" href="/css/home.css">
	<link rel="stylesheet" type="text/css" href="/icomoon/icomoon.css">
	<link rel="stylesheet" type="text/css" href="/css/index.css">
	
	<script defer src="/js/jquery-1.11.0.min.js"></script>
	<script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-HwwvtgBNo3bZJJLYd8oVXjrBZt8cqVSpeBNS5n7C8IVInixGAoxmnlMuBnhbgrkm"
		crossorigin="anonymous"></script>
	<script defer src="/js/plugins.js"></script>
	<script defer src="/js/script.js"></script>
</head>

<% 
	// Robust URL handler normalization between template utilities and controller parameters
	let activeTabId = (typeof query !== 'undefined' && query.activeTab) ? query.activeTab : 'all-genre';
	if (activeTabId === 'all') { activeTabId = 'all-genre'; }
%>

<body data-bs-spy="scroll" data-bs-target="#header" tabindex="0">

	<div id="header-wrap" class="sticky-top bg-white shadow-sm">
		<div class="top-content">
			<div class="container-fluid">
				<div class="row">
					<div class="col-md-6">
						<div class="social-links">
							<ul>
								<li><a href="#"><i class="icon icon-facebook"></i></a></li>
								<li><a href="#"><i class="icon icon-twitter"></i></a></li>
								<li><a href="#"><i class="icon icon-youtube-play"></i></a></li>
								<li><a href="#"><i class="icon icon-behance-square"></i></a></li>
							</ul>
						</div>
					</div>
					<div class="col-md-6">
						<div class="right-element d-flex align-items-center justify-content-end">
							<form action="/logout" method="POST" class="d-inline m-0 p-0 me-3">
								<button type="submit" class="user-login for-buy" style="background: transparent; border: none; padding: 0; margin: 0; font: inherit; color: inherit; cursor: pointer; display: inline-flex; align-items: center; text-transform: inherit; letter-spacing: inherit; position: static;">
									<i class="icon icon-login"></i><span>Logout</span>
								</button>
							</form>  
							<a href="/profile/user" class="user-account for-buy me-3"><i class="icon icon-user"></i><span>Account</span></a>
							<a href="/wishlist" class="user-account for-buy me-3"><i class="icon icon-heart-o"></i><span>Wishlist</span></a>
							<a href="/cart" class="cart for-buy"><i class="icon icon-clipboard"></i><span>Cart:(<%= cartCount %>)</span></a>
						</div>
					</div>
				</div>
			</div>
		</div>
		
		<header id="header">
			<div class="container-fluid">
				<div class="row align-items-center">
					<div class="col-md-2">
						<div class="main-logo">
							<a href="/home"><img src="images/main-logo.png" alt="logo"></a>
						</div>
					</div>

					<div class="col-md-6">
						<nav id="navbar">
							<div class="main-menu stellarnav">
								<ul class="menu-list">
									<li class="menu-item active"><a href="#home">Home</a></li>
									<li class="menu-item"><a href="#featured-books" class="nav-link">Featured</a></li>
									<li class="menu-item"><a href="#popular-books" class="nav-link">Popular</a></li>
									<li class="menu-item"><a href="#special-offer" class="nav-link">Offer</a></li>
									<li class="menu-item"><a href="#latest-blog" class="nav-link">Articles</a></li>
								</ul>
								<div class="hamburger">
									<span class="bar"></span>
									<span class="bar"></span>
									<span class="bar"></span>
								</div>
							</div>
						</nav>
					</div>

					<div class="col-md-4">
						<div class="d-flex justify-nd-end">
							<form role="search" method="get" action="/home" id="searchFormHome" class="navbar-search-form d-flex w-100 position-relative" style="max-width: 300px;">
								
								<% if (typeof query !== 'undefined' && query.sort) { %><input type="hidden" name="sort" value="<%= query.sort %>"><% } %>
								<% if (typeof query !== 'undefined' && query.category) { %><input type="hidden" name="category" value="<%= query.category %>"><% } %>
								<% if (typeof query !== 'undefined' && query.minPrice) { %><input type="hidden" name="minPrice" value="<%= query.minPrice %>"><% } %>
								<% if (typeof query !== 'undefined' && query.maxPrice) { %><input type="hidden" name="maxPrice" value="<%= query.maxPrice %>"><% } %>
								<input type="hidden" name="activeTab" value="all-genre">
					
								<input id="searchInputHome" class="form-control search-input" placeholder="Search books..." type="text" name="search" value="<%= typeof query !== 'undefined' && query.search ? query.search : '' %>" style="padding-right: 35px; border-radius: 20px 0 0 20px;">
								
								<button type="button" id="clearBtnHome" class="clear-search-btn" style="position: absolute; right: 65px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 0; color: #999; font-size: 20px; line-height: 1; z-index: 10; cursor: pointer; display: <%= typeof query !== 'undefined' && query.search ? 'block' : 'none' %>;">
									&times;
								</button>
					
								<button type="submit" class="search-btn">
									<i class="icon icon-search"></i>
								</button>
							</form>
						</div>
					</div>

				</div>
			</div>
		</header>
	</div>

	<section id="billboard">
		<div class="container">
			<div class="row">
				<div class="col-md-12">
					<button class="prev slick-arrow"><i class="icon icon-arrow-left"></i></button>
					<div class="main-slider pattern-overlay">
						<div class="slider-item">
							<div class="banner-content">
								<h2 class="banner-title">Life of the Wild</h2>
								<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed eu feugiat amet, libero ipsum enim pharetra hac.</p>
								<div class="btn-wrap">
									<a href="#" class="btn btn-outline-accent btn-accent-arrow">Read More<i class="icon icon-ns-arrow-right"></i></a>
								</div>
							</div>
							<img src="images/main-banner1.jpg" alt="banner" class="banner-image">
						</div>
						<div class="slider-item">
							<div class="banner-content">
								<h2 class="banner-title">Birds gonna be Happy</h2>
								<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed eu feugiat amet, libero ipsum enim pharetra hac.</p>
								<div class="btn-wrap">
									<a href="#" class="btn btn-outline-accent btn-accent-arrow">Read More<i class="icon icon-ns-arrow-right"></i></a>
								</div>
							</div>
							<img src="images/main-banner2.jpg" alt="banner" class="banner-image">
						</div>
					</div>
					<button class="next slick-arrow"><i class="icon icon-arrow-right"></i></button>
				</div>
			</div>
		</div>
	</section>

	<section id="client-holder" data-aos="fade-up">
		<div class="container">
			<div class="row">
				<div class="inner-content">
					<div class="logo-wrap">
						<div class="grid">
							<a href="#"><img src="images/client-image1.png" alt="client"></a>
							<a href="#"><img src="images/client-image2.png" alt="client"></a>
							<a href="#"><img src="images/client-image3.png" alt="client"></a>
							<a href="#"><img src="images/client-image4.png" alt="client"></a>
							<a href="#"><img src="images/client-image5.png" alt="client"></a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="featured-books" class="py-5 my-5">
		<div class="container">
			<div class="row">
				<div class="col-md-12">
					<div class="section-header align-center">
						<div class="title"><span>Some quality items</span></div>
						<h2 class="section-title">Featured Books</h2>
					</div>
				
					<div class="product-list" data-aos="fade-up">
						<div class="row">
							<% products.forEach(product => { %>
								<div class="col-lg-3 col-md-4 col-sm-6 mb-4">
									<div class="product-item">
										<figure class="product-style">
											<% if (product.images && product.images.length > 0) { %>
												<a href="/product/<%= product._id %>">
													<img src="/uploads/<%= product.images[0] %>" alt="<%= product.title %>" class="img-fluid">
												</a>
											<% } else { %>
												<a href="/product/<%= product._id %>">
													<img src="images/product-item1.jpg" alt="Books" class="img-fluid">
												</a>
											<% } %>
											<button type="button" class="add-to-cart" onclick="addToCart('<%= product._id %>')">Add to Cart</button>
										</figure>
										<figcaption>
											<h3><%= product.title %></h3>
											<span><%= product.author %></span>
											<div class="item-price">₹<%= product.price %></div>
										</figcaption>
									</div>
								</div>
							<% }) %>
						</div>

						<div class="pagination mt-4 d-flex gap-2 justify-content-center">
							<a href="<%= featuredPage > 1 ? getPageUrl('page_featured', featuredPage - 1, '#featured-books') : '#' %>"
							   class="btn btn-sm btn-outline-dark <%= featuredPage <= 1 ? 'disabled' : '' %>">
								&laquo; Prev
							</a>
							
							<% for(let i = 1; i <= featuredTotalPages; i++) { %>
								<a href="<%= getPageUrl('page_featured', i, '#featured-books') %>"
								   class="btn btn-sm <%= featuredPage === i ? 'btn-dark' : 'btn-outline-dark' %>">
									<%= i %>
								</a>
							<% } %>
						
							<a href="<%= featuredPage < featuredTotalPages ? getPageUrl('page_featured', featuredPage + 1, '#featured-books') : '#' %>"
							   class="btn btn-sm btn-outline-dark <%= featuredPage >= featuredTotalPages ? 'disabled' : '' %>">
								Next &raquo;
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="best-selling" class="leaf-pattern-overlay">
		<div class="corner-pattern-overlay"></div>
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-md-8">
					<div class="row">
						<div class="col-md-6">
							<figure class="products-thumb">
								<img src="images/single-image.jpg" alt="book" class="single-image">
							</figure>
						</div>
						<div class="col-md-6">
							<div class="product-entry">
								<h2 class="section-title divider">Best Selling Book</h2>
								<div class="products-content">
									<div class="author-name">By Timbur Hood</div>
									<h3 class="item-title">Birds gonna be happy</h3>
									<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
									<div class="item-price">$ 45.00</div>
									<div class="btn-wrap">
										<a href="#" class="btn-accent-arrow">shop it now <i class="icon icon-ns-arrow-right"></i></a>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="popular-books" class="bookshelf py-5 my-5">
		<div class="container">
			<div class="row">
				<div class="col-md-12">
					<div class="section-header align-center">
						<div class="title"><span>Browse Books</span></div>
						<h2 class="section-title">Popular Books</h2>
					</div>

					<div class="filter-sort-bar mb-4 p-3 bg-light rounded border" data-aos="fade-up">
						<form method="get" action="/home" class="row g-3 align-items-end">
							<% if (typeof query !== 'undefined' && query.search) { %>
								<input type="hidden" name="search" value="<%= query.search %>">
							<% } %>
							<input type="hidden" name="activeTab" value="all-genre">

							<div class="col-lg-3 col-md-6">
								<label class="form-label mb-1" style="font-size: 0.85em; font-weight: 600;">Category</label>
								<select name="category" class="form-select form-select-sm">
									<option value="">All Categories</option>
									<% categoryData.forEach(item => { %>
										<option value="<%= item.category._id %>" <%= typeof query !== 'undefined' && query.category == item.category._id ? 'selected' : '' %>>
											<%= item.category.name %>
										</option>
									<% }) %>
								</select>
							</div>

							<div class="col-lg-4 col-md-6">
								<label class="form-label mb-1" style="font-size: 0.85em; font-weight: 600;">Price Range (₹)</label>
								<div class="d-flex gap-2 align-items-center">
									<input type="number" name="minPrice" class="form-control form-control-sm" placeholder="Min" value="<%= typeof query !== 'undefined' ? query.minPrice : '' %>" min="0">
									<span>-</span>
									<input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="Max" value="<%= typeof query !== 'undefined' ? query.maxPrice : '' %>" min="0">
								</div>
							</div>

							<div class="col-lg-3 col-md-6">
								<label class="form-label mb-1" style="font-size: 0.85em; font-weight: 600;">Sort By</label>
								<select name="sort" class="form-select form-select-sm">
									<option value="">Default (Newest)</option>
									<option value="price_asc" <%= typeof query !== 'undefined' && query.sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
									<option value="price_desc" <%= typeof query !== 'undefined' && query.sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
									<option value="az" <%= typeof query !== 'undefined' && query.sort === 'az' ? 'selected' : '' %>>Title: A - Z</option>
									<option value="za" <%= typeof query !== 'undefined' && query.sort === 'za' ? 'selected' : '' %>>Title: Z - A</option>
								</select>
							</div>

							<div class="col-lg-2 col-md-6 d-flex gap-2">
								<button type="submit" class="btn btn-dark btn-sm flex-grow-1 m-0" style="height: 31px;">Apply</button>
								<a href="/home?activeTab=all-genre#popular-books" class="btn btn-outline-secondary btn-sm flex-grow-1 m-0 d-flex align-items-center justify-content-center" style="height: 31px;">Clear</a>
							</div>
						</form>
					</div>

					<ul class="tabs">
						<li class="tab <%= activeTabId === 'all-genre' ? 'active' : '' %>" data-tab-target="#all-genre">All Genre</li>
						<% categoryData.forEach(item => { %>
							<li class="tab <%= activeTabId === 'cat-' + item.category._id ? 'active' : '' %>" data-tab-target="#cat-<%= item.category._id %>">
								<%= item.category.name %>
							</li>
						<% }) %>
					</ul>

					<div class="tab-content">
						<div id="all-genre" data-tab-content class="<%= activeTabId === 'all-genre' ? 'active' : '' %>">
							<div class="row">
								<% if (allProducts && allProducts.length === 0) { %>
									<p class="text-muted p-3">No products matched your search or filters.</p>
								<% } %>
								<% if (allProducts) { %>
									<% allProducts.forEach(product => { %>
										<div class="col-lg-3 col-md-4 col-sm-6 mb-4">
											<div class="product-item">
												<figure class="product-style">
													<% if(product.images && product.images.length > 0){ %>
														<a href="/product/<%= product._id %>">
															<img src="/uploads/<%= product.images[0] %>" class="img-fluid">
														</a>
													<% } else { %>
														<a href="/product/<%= product._id %>">
															<img src="images/product-item1.jpg" class="img-fluid">
														</a>
													<% } %>
													<button class="add-to-cart" onclick="addToCart('<%= product._id %>')">Add To Cart</button>
												</figure>
												<figcaption>
													<h3><%= product.title %></h3>
													<span><%= product.author %></span>
													<div class="item-price">₹<%= product.price %></div>
												</figcaption>
											</div>
										</div>
									<% }) %>
								<% } %>
							</div>
							
							<div class="pagination mt-4 d-flex gap-2 justify-content-center">
								<a href="<%= allPage > 1 ? getPageUrl('page_all', allPage - 1, '#popular-books', activeTabId) : '#' %>"
								   class="btn btn-sm btn-outline-dark <%= allPage <= 1 ? 'disabled' : '' %>">
									&laquo; Prev
								</a>
								
								<% for(let i = 1; i <= allTotalPages; i++) { %>
									<a href="<%= getPageUrl('page_all', i, '#popular-books', activeTabId) %>"
									   class="btn btn-sm <%= allPage === i ? 'btn-dark' : 'btn-outline-dark' %>">
										<%= i %>
									</a>
								<% } %>
								
								<a href="<%= allPage < allTotalPages ? getPageUrl('page_all', allPage + 1, '#popular-books', activeTabId) : '#' %>"
								   class="btn btn-sm btn-outline-dark <%= allPage >= allTotalPages ? 'disabled' : '' %>">
									Next &raquo;
								</a>
							</div>
						</div>

						<% categoryData.forEach(item => { %>
							<div id="cat-<%= item.category._id %>" data-tab-content class="<%= activeTabId === 'cat-' + item.category._id ? 'active' : '' %>">
								<div class="row">
									<% if (item.products.length === 0) { %>
										<p class="text-muted p-3">No products in this category</p>
									<% } %>
									<% item.products.forEach(product => { %>
										<div class="col-lg-3 col-md-4 col-sm-6 mb-4">
											<div class="product-item">
												<figure class="product-style">
													<% if(product.images && product.images.length > 0){ %>
														<a href="/product/<%= product._id %>">
															<img src="/uploads/<%= product.images[0] %>" class="img-fluid">
														</a>
													<% } else { %>
														<a href="/product/<%= product._id %>">
															<img src="images/product-item1.jpg" class="img-fluid">
														</a>
													<% } %>
													<button class="add-to-cart" onclick="addToCart('<%= product._id %>')">Add To Cart</button>
												</figure>
												<figcaption>
													<h3><%= product.title %></h3>
													<span><%= product.author %></span>
													<div class="item-price">₹<%= product.price %></div>
												</figcaption>
											</div>
										</div>
									<% }) %>
								</div>
								
								<div class="pagination mt-4 d-flex gap-2 justify-content-center">
									<a href="<%= item.page > 1 ? getPageUrl('page_' + item.category._id, item.page - 1, '#popular-books', 'cat-' + item.category._id) : '#' %>"
									   class="btn btn-sm btn-outline-dark <%= item.page <= 1 ? 'disabled' : '' %>">
										&laquo; Prev
									</a>
									
									<% for(let i = 1; i <= item.totalPages; i++){ %>
										<a href="<%= getPageUrl('page_' + item.category._id, i, '#popular-books', 'cat-' + item.category._id) %>"
										   class="btn btn-sm <%= item.page === i ? 'btn-dark' : 'btn-outline-dark' %>">
											<%= i %>
										</a>
									<% } %>
									
									<a href="<%= item.page < item.totalPages ? getPageUrl('page_' + item.category._id, item.page + 1, '#popular-books', 'cat-' + item.category._id) : '#' %>"
									   class="btn btn-sm btn-outline-dark <%= item.page >= item.totalPages ? 'disabled' : '' %>">
										Next &raquo;
									</a>
								</div>
							</div>
						<% }) %>
					</div>

				</div>
			</div>
		</div>
	</section>

	<section id="quotation" class="align-center pb-5 mb-5">
		<div class="inner-content">
			<h2 class="section-title divider">Quote of the day</h2>
			<blockquote data-aos="fade-up">
				<q>“The more that you read, the more things you will know. The more that you learn, the more places you’ll go.”</q>
				<div class="author-name">Dr. Seuss</div>
			</blockquote>
		</div>
	</section>

	<section id="special-offer" class="bookshelf pb-5 mb-5">
		<div class="section-header align-center">
			<div class="title"><span>Grab your opportunity</span></div>
			<h2 class="section-title">Books with offer</h2>
		</div>
		<div class="container">
			<div class="row">
				<div class="inner-content">
					<div class="product-list" data-aos="fade-up">
						<div class="row">
							<% offerProducts.forEach(product => { %>
								<div class="col-lg-3 col-md-4 col-sm-6 mb-4">
									<div class="product-item">
										<figure class="product-style">
											<a href="/product/<%= product._id %>">
												<% if (product.images && product.images.length > 0) { %>
													<img src="/uploads/<%= product.images[0] %>" alt="<%= product.title %>" class="img-fluid">
												<% } else { %>
													<img src="images/product-item5.jpg" alt="Books" class="img-fluid">
												<% } %>
											</a>
											<button type="button" class="add-to-cart" onclick="addToCart('<%= product._id %>')">Add to Cart</button>
										</figure>
										<figcaption>
											<h3><%= product.title %></h3>
											<span><%= product.author %></span>
											<div class="item-price">
												<% if (product.oldPrice) { %>
													<span class="prev-price">₹<%= product.oldPrice %></span>
												<% } %>
												₹<%= product.price %>
											</div>
										</figcaption>
									</div>
								</div>
							<% }) %>
						</div>
						
						<div class="pagination mt-4 d-flex gap-2 justify-content-center">
							<a href="<%= offerPage > 1 ? getPageUrl('page_offer', offerPage - 1, '#special-offer') : '#' %>" 
							   class="btn btn-sm btn-outline-dark <%= offerPage <= 1 ? 'disabled' : '' %>">
								&laquo; Prev
							</a>
							
							<% for(let i = 1; i <= offerTotalPages; i++) { %>
								<a href="<%= getPageUrl('page_offer', i, '#special-offer') %>" class="btn btn-sm <%= offerPage === i ? 'btn-dark' : 'btn-outline-dark' %>">
									<%= i %>
								</a>
							<% } %>
							
							<a href="<%= offerPage < offerTotalPages ? getPageUrl('page_offer', offerPage + 1, '#special-offer') : '#' %>" 
							   class="btn btn-sm btn-outline-dark <%= offerPage >= offerTotalPages ? 'disabled' : '' %>">
								Next &raquo;
							</a>
						</div>
					</div>
				</div>
