
<%- include('../partials/header') %>

<!-- HEADER -->
<header class="top-header">

    <div class="social-icons">
        <i class="fab fa-facebook-f"></i>
        <i class="fab fa-twitter"></i>
        <i class="fab fa-pinterest"></i>
        <i class="fab fa-instagram"></i>
    </div>

    <div class="header-right">
        <a href="/profile">Account</a>
        <i class="fa-solid fa-heart"></i>
        <i class="fa-solid fa-magnifying-glass"></i>
    </div>

</header>

<!-- NAVBAR -->
<nav class="navbar">

    <div class="logo">
        Lantern & Leaf
    </div>

    <ul class="nav-links">
        <li><a href="/home">Home</a></li>
        <li><a href="#">Featured</a></li>
        <li><a href="#">Popular</a></li>
        <li><a href="#">Offer</a></li>
        <li><a href="#">Articles</a></li>
    </ul>

</nav>

<!-- PAGE -->
<section class="add-address-page">

    <div class="page-header">

        <p class="breadcrumb">
            HOME /
            MY ACCOUNT /
            <span>EDIT ADDRESS</span>
        </p>

        <h1>
            Edit Address
        </h1>

    </div>

    <div class="form-container">

        <form
            action="/address/<%= address._id %>?_method=PUT"
            method="POST"
            class="address-form"
        >

            <div class="form-group">

                <label>
                    Full Name
                </label>

                <input
                    type="text"
                    name="fullName"
                    value="<%= address.fullName %>"
                    required
                    id="fullName"
                />
                <small id="fullNameError"></small>

            </div>

            <div class="form-group">

                <label>
                    Phone Number
                </label>

                <input
                    type="text"
                    name="phone"
                    value="<%= address.phone %>"
                    required
                    id="phone"
                />
                <small id="phoneError"></small>
            </div>

            <div class="form-group">

                <label>
                    House / Flat / Building
                </label>

                <input
                    type="text"
                    name="house"
                    value="<%= address.addressLine.split(',')[0]?.trim() || '' %>"
                    required
                    id="house"
                />
<small id="houseError"></small>
            </div>

            <div class="form-group">

                <label>
                    Area / Street
                </label>

                <input
                    type="text"
                    name="area"
                    value="<%= address.addressLine.split(',')[1]?.trim() || '' %>"
                    required
                    id="area"
                />
<small id="areaError"></small>
            </div>

            <div class="form-group">

                <label>
                    Landmark
                </label>

                <input
                    type="text"
                    name="landmark"
                    value="<%= address.landmark || '' %>"
                    placeholder="Nearby landmark"
                    id="landmark"
                />
<small id="landmarkError"></small>
            </div>

            <div class="two-col">

                <div class="form-group">

                    <label>
                        City
                    </label>

                    <input
                        type="text"
                        name="city"
                        value="<%= address.city %>"
                        required
                        id="city"
                    />
<small id="cityError"></small>
                </div>

                <div class="form-group">

                    <label>
                        State
                    </label>

                    <input
                        type="text"
                        name="state"
                        value="<%= address.state %>"
                        required
      
                    />

                </div>

            </div>

            <div class="two-col">

                <div class="form-group">

                    <label>
                        Pincode
                    </label>

                    <input
                        type="text"
                        name="pincode"
                        value="<%= address.pincode %>"
                        required
                        id="pincode"
                    />
            <small id="pincodeError"></small>
                </div>

                <div class="form-group">

                    <label>
                        Address Type
                    </label>

                    <select
                        name="addressType"
                        required
                    >
                        <option value="">
                            Select
                        </option>

                        <option
                            value="Home"
                            <%= address.addressType === 'Home' ? 'selected' : '' %>
                        >
                            Home
                        </option>

                        <option
                            value="Office"
                            <%= address.addressType === 'Office' ? 'selected' : '' %>
                        >
                            Office
                        </option>

                    </select>

                </div>

            </div>

            <div class="btn-group">

                <a
                    href="/address"
                    class="cancel-btn"
                >
                    Cancel
                </a>

                <button
                    type="submit"
                    class="save-btn"
                    id="update-btn"
                >
                    Update Address
                </button>

            </div>

        </form>

    </div>

</section>

<%- include('../partials/footer') %>

