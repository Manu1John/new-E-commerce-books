<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> | BookStore</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet"
		integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">

	<link rel="stylesheet" href="/css/home.css">
	<link rel="stylesheet" type="text/css" href="/icomoon/icomoon.css">
	<link rel="stylesheet" type="text/css" href="/css/index.css">

	<style>
		.address-card {
			border: 1px solid #ddd;
			border-radius: 6px;
			padding: 15px;
			margin-bottom: 15px;
			cursor: pointer;
			transition: border-color 0.2s, background-color 0.2s;
			position: relative;
		}
		.address-card:hover {
			border-color: #C5A992;
		}
		.address-card input[type="radio"] {
			position: absolute;
			right: 15px;
			top: 15px;
		}
		.address-card.selected {
			border-color: #C5A992;
			background-color: #Fcfaf7;
		}
		.badge-type {
			font-size: 0.75em;
			background: #eee;
			color: #555;
			padding: 2px 6px;
			border-radius: 4px;
			text-transform: uppercase;
		}
	</style>

	<script defer src="/js/jquery-1.11.0.min.js"></script>
	<script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-HwwvtgBNo3bZJJLYd8oVXjrBZt8cqVSpeBNS5n7C8IVInixGAoxmnlMuBnhbgrkm"
		crossorigin="anonymous"></script>
	<script defer src="/js/plugins.js"></script>
	<script defer src="/js/script.js"></script>
</head>
<body>

	<div id="header-wrap" class="sticky-top bg-white shadow-sm">
		<div class="top-content">
			<div class="container-fluid">
				<div class="row">
					<div class="col-md-6">
						<div class="social-links">
							<ul>
								<li><a href="#"><i class="icon icon-facebook"></i></a></li>
								<li><a href="#"><i class="icon icon-twitter"></i></a></li>
								<li><a href="#"><i class="icon icon-youtube-play"></i></a></li>
								<li><a href="#"><i class="icon icon-behance-square"></i></a></li>
							</ul>
						</div>
					</div>
					<div class="col-md-6">
						<div class="right-element d-flex align-items-center justify-content-end">
							<form action="/logout" method="POST" class="d-inline m-0 p-0 me-3">
								<button type="submit" class="user-login for-buy" style="background: transparent; border: none; padding: 0; margin: 0; font: inherit; color: inherit; cursor: pointer; display: inline-flex; align-items: center; text-transform: inherit; letter-spacing: inherit; position: static;">
									<i class="icon icon-login"></i><span>Logout</span>
								</button>
							</form>  
							<a href="/profile/user" class="user-account for-buy me-3"><i class="icon icon-user"></i><span>Account</span></a>
							<a href="/cart" class="cart for-buy"><i class="icon icon-clipboard"></i><span>Cart:(<%= cartCount %>)</span></a>
						</div>
					</div>
				</div>
			</div>
		</div>
		
		<header id="header">
			<div class="container-fluid">
				<div class="row align-items-center">
					<div class="col-md-2">
						<div class="main-logo">
							<a href="/home"><img src="/images/main-logo.png" alt="logo"></a>
						</div>
					</div>
				</div>
			</div>
		</header>
	</div>

	<main class="container my-5 animate-fade-in">
		<h2 class="mb-4" style="font-family: var(--heading-font);">Checkout</h2>

		<div class="row g-5">
			<!-- Delivery Address List -->
			<div class="col-lg-7">
				<h4 class="mb-3" style="font-family: var(--heading-font);">1. Select Delivery Address</h4>
				
				<% if (addresses.length === 0) { %>
					<div class="alert alert-warning p-4 rounded text-center">
						<p class="mb-3">You don't have any saved delivery addresses.</p>
						<a href="/profile/address/add" class="btn btn-dark btn-sm px-3 py-2">Add New Address</a>
					</div>
				<% } else { %>
					<div class="address-container">
						<% addresses.forEach((addr, idx) => { %>
							<div class="address-card <%= idx === 0 ? 'selected' : '' %>" onclick="selectAddress(this, '<%= addr._id %>')">
								<input type="radio" name="selectedAddr" value="<%= addr._id %>" <%= idx === 0 ? 'checked' : '' %>>
								<div class="d-flex align-items-center gap-2 mb-2">
									<strong><%= addr.fullName %></strong>
									<span class="badge-type"><%= addr.addressType %></span>
								</div>
								<p class="mb-1 text-secondary" style="font-size:0.9em;"><%= addr.house %>, <%= addr.area %></p>
								<% if (addr.landmark) { %>
									<p class="mb-1 text-secondary" style="font-size:0.9em;">Landmark: <%= addr.landmark %></p>
								<% } %>
								<p class="mb-1 text-secondary" style="font-size:0.9em;"><%= addr.city %>, <%= addr.state %> - <%= addr.pincode %></p>
								<p class="mb-0 text-secondary" style="font-size:0.9em;"><i class="icon icon-phone"></i> Phone: <%= addr.phone %></p>
							</div>
						<% }) %>
					</div>
					<div class="mt-3">
						<a href="/profile/address/add" class="btn btn-outline-dark btn-sm"><i class="icon icon-plus"></i> Add Another Address</a>
					</div>
				<% } %>
			</div>

			<!-- Order Summary -->
			<div class="col-lg-5">
				<div class="card p-4 border-0 bg-light rounded shadow-sm">
					<h4 class="mb-3" style="font-family: var(--heading-font);">2. Order Items</h4>
					<div class="order-items-list mb-4" style="max-height: 250px; overflow-y: auto;">
						<% items.forEach(item => { %>
							<div class="d-flex justify-content-between align-items-center py-2 border-bottom">
								<div>
									<h6 class="mb-0 text-truncate" style="max-width: 250px;"><%= item.product.title %></h6>
									<small class="text-muted">Qty: <%= item.quantity %> x ₹<%= item.product.price %></small>
								</div>
								<strong>₹<%= item.product.price * item.quantity %></strong>
							</div>
						<% }) %>
					</div>

					<div class="d-flex justify-content-between mb-2">
						<span class="text-muted">Subtotal:</span>
						<strong>₹<%= cartSubtotal %></strong>
					</div>
					<div class="d-flex justify-content-between mb-2">
						<span class="text-muted">Shipping:</span>
						<span class="text-success">FREE</span>
					</div>
					<hr>
					<div class="d-flex justify-content-between mb-4">
						<span class="fs-5">Grand Total:</span>
						<strong class="fs-4 text-dark">₹<%= cartSubtotal %></strong>
					</div>

					<% if (addresses.length > 0) { %>
						<button class="btn btn-dark w-100 py-3" style="font-weight: 600; text-transform: uppercase; letter-spacing: 1px;" onclick="placeOrder()">
							Place Order (COD)
						</button>
					<% } else { %>
						<button class="btn btn-dark w-100 py-3 disabled" disabled>
							Add address to checkout
						</button>
					<% } %>
				</div>
			</div>
		</div>
	</main>

	<!-- Footer -->
	<footer id="footer" class="bg-dark text-white py-5 mt-5">
		<div class="container text-center text-muted">
			<p>© 2026 Premium Booksaw Shop. All rights reserved.</p>
		</div>
	</footer>

	<script>
		let selectedAddressId = '<%= addresses.length > 0 ? addresses[0]._id : "" %>';

		function selectAddress(element, addressId) {
			document.querySelectorAll('.address-card').forEach(card => card.classList.remove('selected'));
			element.classList.add('selected');
			element.querySelector('input[type="radio"]').checked = true;
			selectedAddressId = addressId;
		}

		function placeOrder() {
			if (!selectedAddressId) {
				alert('Please select a delivery address.');
				return;
			}

			fetch('/checkout/place', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ addressId: selectedAddressId })
			})
			.then(res => res.json())
			.then(data => {
				if (data.success) {
					alert(data.message);
					window.location.href = data.redirectUrl;
				} else {
					alert(data.error || 'Failed to place order.');
				}
			})
			.catch(err => console.error(err));
		}
	</script>
</body>
</html>
