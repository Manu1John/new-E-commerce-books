
	<title><%= title %> | BookStore</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet"
		integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
	<link rel="stylesheet" href="/css/home.css">
	<link rel="stylesheet" type="text/css" href="/icomoon/icomoon.css">
	<link rel="stylesheet" type="text/css" href="/css/index.css">
	<link rel="stylesheet" type="text/css" href="/css/wishlist.css">
	<script defer src="/js/wishlist.js"></script>

	
	<script defer src="/js/jquery-1.11.0.min.js"></script>
	<script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-HwwvtgBNo3bZJJLYd8oVXjrBZt8cqVSpeBNS5n7C8IVInixGAoxmnlMuBnhbgrkm"
		crossorigin="anonymous"></script>
	<script defer src="/js/plugins.js"></script>
	<script defer src="/js/script.js"></script>
</head>
<body>

	<div id="header-wrap" class="sticky-top bg-white shadow-sm">
		<div class="top-content">
			<div class="container-fluid">
				<div class="row">
					<div class="col-md-6">
						<div class="social-links">
							<ul>
								<li><a href="#"><i class="icon icon-facebook"></i></a></li>
								<li><a href="#"><i class="icon icon-twitter"></i></a></li>
								<li><a href="#"><i class="icon icon-youtube-play"></i></a></li>
								<li><a href="#"><i class="icon icon-behance-square"></i></a></li>
							</ul>
						</div>
					</div>
					<div class="col-md-6">
						<div class="right-element d-flex align-items-center justify-content-end">
							<form action="/logout" method="POST" class="d-inline m-0 p-0 me-3">
								<button type="submit" class="user-login for-buy" style="background: transparent; border: none; padding: 0; margin: 0; font: inherit; color: inherit; cursor: pointer; display: inline-flex; align-items: center; text-transform: inherit; letter-spacing: inherit; position: static;">
									<i class="icon icon-login"></i><span>Logout</span>
								</button>
							</form>  
							<a href="/profile/user" class="user-account for-buy me-3"><i class="icon icon-user"></i><span>Account</span></a>
							<a href="/cart" class="cart for-buy"><i class="icon icon-clipboard"></i><span>Cart:(<%= cartCount %>)</span></a>
						</div>
					</div>
				</div>
			</div>
		</div>
		
		<header id="header">
			<div class="container-fluid">
				<div class="row align-items-center">
					<div class="col-md-2">
						<div class="main-logo">
							<a href="/home"><img src="/images/main-logo.png" alt="logo"></a>
						</div>
					</div>
					<div class="col-md-6">
						<nav id="navbar">
							<div class="main-menu stellarnav">
								<ul class="menu-list">
									<li class="menu-item"><a href="/home">Home</a></li>
									<li class="menu-item"><a href="/home#featured-books">Featured</a></li>
									<li class="menu-item"><a href="/home#popular-books">Popular</a></li>
									<li class="menu-item"><a href="/home#special-offer">Offer</a></li>
									<li class="menu-item"><a href="/home#latest-blog">Articles</a></li>
								</ul>
							</div>
						</nav>
					</div>
				</div>
			</div>
		</header>
	</div>

	<main class="container my-5">
		<h2 class="mb-4" style="font-family: var(--heading-font);">My Wishlist</h2>

		<!-- Alert Flash Warnings -->
		<% if (success && success.length > 0) { %>
			<div class="alert alert-success alert-dismissible fade show" role="alert">
				<%= success %>
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		<% } %>
		<% if (error && error.length > 0) { %>
			<div class="alert alert-danger alert-dismissible fade show" role="alert">
				<%= error %>
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		<% } %>

		<% if (products.length === 0) { %>
			<div class="text-center py-5 border rounded bg-light">
				<p class="text-muted mb-4" style="font-size: 1.2em;">Your wishlist is currently empty.</p>
				<a href="/home" class="btn btn-dark px-4 py-2" style="font-weight: 600;">Browse Books</a>
			</div>
		<% } else { %>
			<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="wishlist-container">
				<% products.forEach(product => { %>
					<div class="col" id="product-card-<%= product._id %>">
						<div class="wishlist-item d-flex flex-column h-100">
							<a href="/product/<%= product._id %>">
								<% if (product.images && product.images.length > 0) { %>
									<img src="/uploads/<%= product.images[0] %>" class="wishlist-img" alt="<%= product.title %>">
								<% } else { %>
									<img src="/images/product-item1.jpg" class="wishlist-img" alt="<%= product.title %>">
								<% } %>
							</a>
							<div class="p-3 d-flex flex-column flex-grow-1">
								<h5 class="mb-1" style="font-size: 1.05em; font-family: var(--heading-font); text-overflow: ellipsis; white-space: nowrap; overflow: hidden;" title="<%= product.title %>">
									<a href="/product/<%= product._id %>" class="text-decoration-none text-dark"><%= product.title %></a>
								</h5>
								<span class="text-muted d-block mb-2" style="font-size: 0.85em;">By <%= product.author %></span>
								<div class="mt-auto">
									<div class="d-flex justify-content-between align-items-center mb-3">
										<span class="fw-bold" style="color: var(--dark-color);">₹<%= product.price %></span>
										<% if (product.quantity > 0) { %>
											<span class="badge bg-success-subtle text-success border border-success-subtle">In Stock</span>
										<% } else { %>
											<span class="badge bg-danger-subtle text-danger border border-danger-subtle">Sold Out</span>
										<% } %>
									</div>
									<div class="d-flex gap-2">
										<% if (product.quantity > 0) { %>
											<button class="btn btn-dark btn-sm btn-wishlist-action flex-grow-1" onclick="moveToCart('<%= product._id %>')">
												Cart
											</button>
										<% } else { %>
											<button class="btn btn-secondary btn-sm btn-wishlist-action flex-grow-1" disabled>
												Out of Stock
											</button>
										<% } %>
										<button class="btn btn-outline-danger btn-sm btn-wishlist-action" onclick="removeFromWishlist('<%= product._id %>')">
											✕
										</button>
									</div>
								</div>
							</div>
						</div>
					</div>
				<% }) %>
			</div>
		<% } %>
	</main>

	<!-- Footer -->
	<footer id="footer" class="bg-dark text-white py-5 mt-5">
		<div class="container text-center text-muted">
			<p>© 2026 Premium Booksaw Shop. All rights reserved.</p>
		</div>
	</footer>

</body>

