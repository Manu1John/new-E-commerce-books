<%- include('../partials/header') %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

<div class="page-wrapper">

    <div class="product-layout">

        <div class="product-card">

            <h2>Edit Product Information</h2>

            <form
                action="/admin/product/<%= product._id %>/edit"
                method="POST"
                enctype="multipart/form-data"
            >

                <div class="form-group">
                    <label>
                        Product Name <span>*</span>
                    </label>
                    <input
                        type="text"
                        name="title"
                        id="title"
                        placeholder="Enter product name"
                        value="<%= product.title %>"
                    >
                    <span class="error-message" id="titleError"></span>
                </div>

                <div class="form-group">
                    <label>
                        Category <span>*</span>
                    </label>
                    <select
                        name="category"
                        id="category"
                    >
                        <option value="">
                            Select category
                        </option>
                        <% categories.forEach(category => { %>
                            <option 
                                value="<%= category._id %>" 
                                <%= product.category && (product.category._id || product.category).toString() === category._id.toString() ? 'selected' : '' %>
                            >
                                <%= category.name %>
                            </option>
                        <% }) %>
                    </select>
                    <span class="error-message" id="categoryError"></span>
                </div>

                <div class="form-group">
                    <label>
                        Author <span>*</span>
                    </label>
                    <input
                        type="text"
                        name="author"
                        id="author"
                        placeholder="Enter author name"
                        value="<%= product.author %>"
                    >
                    <span class="error-message" id="authorError"></span>
                </div>

                <div class="form-group">
                    <label>
                        Description <span>*</span>
                    </label>
                    <textarea
                        name="description"
                        id="description"
                        rows="5"
                        placeholder="Enter product description"
                    ><%= product.description %></textarea>
                    <span class="error-message" id="descriptionError"></span>
                </div>

                <div class="row">

                    <div class="form-group">
                        <label>
                            Price <span>*</span>
                        </label>
                        <div class="input-box">
                            <span>₹</span>
                            <input
                                type="number"
                                name="price"
                                id="price"
                                placeholder="Enter price"
                                value="<%= product.price %>"
                            >
                        </div>
                        <span class="error-message" id="priceError"></span>
                    </div>

                    <div class="form-group">
                        <label>
                            Stock <span>*</span>
                        </label>
                        <input
                            type="number"
                            name="quantity"
                            id="quantity"
                            placeholder="Enter stock"
                            value="<%= product.quantity %>"
                        >
                        <span class="error-message" id="quantityError"></span>
                    </div>

                </div>

                <div class="form-group">
                    <label>Status</label>
                    <div class="radio-group">
                        <label class="radio-option">
                            <input
                                type="radio"
                                name="status"
                                value="active"
                                <%= product.status === 'active' ? 'checked' : '' %>
                            >
                            Active
                        </label>
                        <label class="radio-option">
                            <input
                                type="radio"
                                name="status"
                                value="inactive"
                                <%= product.status === 'inactive' ? 'checked' : '' %>
                            >
                            Not Active
                        </label>
                    </div>
                </div>

                <div class="upload-card">
                    <h3>Product Images</h3>
                    
                    <% if (product.images && product.images.length > 0) { %>
                        <div class="current-images-gallery" style="margin-bottom: 20px;">
                            <p style="font-weight: 600; font-size: 14px; margin-bottom: 8px; color: #4b5563;">Current Saved Images:</p>
                            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                                <% product.images.forEach(img => { %>
                                    <img src="/uploads/<%= img %>" alt="Product Image" style="width: 70px; height: 70px; object-fit: cover; border-radius: 6px; border: 1px solid #e5e7eb;">
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <div
                        class="upload-box"
                        id="dropArea"
                    >
                        <input
                            type="file"
                            id="imageUpload"
                            name="images"
                            multiple
                            accept="image/*"
                            hidden
                        >
                        <div id="uploadContent">
                            <div class="upload-icon">
                                <i class="fa-solid fa-cloud-arrow-up"></i>
                            </div>
                            <h4>Click or Drag New Images to Replace</h4>
                            <p>Minimum 3 Images</p>
                            <small>Maximum 5 Images</small>
                        </div>
                    </div>
                    
                    <span class="error-message" id="imageError" style="text-align: center; margin-top: 10px;"></span>

                    <div
                        id="previewContainer"
                        class="preview-container"
                    ></div>
                </div>

                <div class="button-group">
                    <button
                        type="submit"
                        class="save-btn"
                    >
                        Update Product
                    </button>
                    <button
                        type="button"
                        class="reset-btn"
                        onclick="window.location.href='/admin/products'"
                    >
                        Cancel
                    </button>
                </div>

            </form>

        </div>

        <div class="sidebar-card">
            <div class="tips-card">
                <h3>💡 Quick Tips</h3>
                <ul>
                    <li>Enter accurate product information</li>
                    <li>Leaving image inputs blank preserves old images</li>
                    <li>Use high-quality images</li>
                    <li>Set correct stock quantity</li>
                    <li>Check category before saving</li>
                </ul>
            </div>
        </div>

    </div>

</div>

<script src="/js/editProduct.js"></script>

<%- include('../partials/footer') %>